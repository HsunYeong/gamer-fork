# problem-specific runtime parameters
CM_MaxR                 0.13856406460551018      # maximum radius for determining CM
CM_TolErrR              1e-3                     # maximum allowed errors for determining CM
ComputeCorrelation      1                        # compute correlation function
Fluid_Periodic_BC_Flag  1                        # flag for checking the fluid boundary condtion is setup to periodic (0: user defined; 1: periodic)

# parameters for correlation function (only useful when ComputeCorrelation=1)
dr_min_corr             0.00234224               # granule_diameter
RadiusMax_corr          0.04                     # 0.5*BoxSize
LogBin_corr             1                        # use log bin
LogBinRatio_corr        1.1940617521534918       # 16 log bins -> exp((log(RadiusMax_corr)-log(dr_min_corr))/16)
dr_min_prof             0.00058606               # 0.25*granule_diameter
FilePath_corr           ./Record__Correlation    # output path for correlation function text files
MinLv                   0                        # do statistics from MinLv to MaxLv (default=0)
MaxLv                   0                        # do statistics from MinLv to MaxLv (default=MAX_LEVEL)
ReComputeCorrelation    0                        # use the simulation time of RESTART as initial time for computing time correlation; only available for RESTART
OutputCorrelationMode   0                        # output correlation function mode=> 0: constant interval 1: by table
StepInitial             0                        # inital step for recording correlation function (only for OutputCorrelationMode=0) (default=0)
StepInterval            100                      # interval for recording correlation function (only for OutputCorrelationMode=0) (default=1)
RemoveEmpty_prof        0                        # remove 0 sample bins; false: Data[empty_bin]=Weight[empty_bin]=NCell[empty_bin]=0 (profile)
